# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: used by /api/expire-quotations (RPC via service role).
# NEVER expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — OCR/extraction in /api/process-image
# (OpenAI was replaced by Gemini; OPENAI_API_KEY is no longer used by the app)
GOOGLE_API_KEY=your-google-api-key

# Resend — quotation emails in /api/send-quotation
RESEND_API_KEY=your-resend-api-key

# Vercel Cron auth for /api/expire-quotations.
# Set the same value in the Vercel project env; Vercel sends it as
# "Authorization: Bearer <CRON_SECRET>" with cron invocations.
CRON_SECRET=generate-a-long-random-string
